# Copy this file to `.env` and fill in real values.
# The `.env` file holds secrets and is NEVER committed to git.

# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# --- Database (production / PostgreSQL only) ---
# Local development uses SQLite automatically and ignores these.
DB_NAME=alsayyad
DB_USER=alsayyad
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432
